# The target URL that the local Vite dev server will proxy "/api" requests to.
VITE_PROXY_TARGET=http://localhost:8000

# The base URL for the API. 
# In development, if this is empty, it defaults to "/api" which uses the local proxy defined above.
# For production deployment, set this to your deployed API's fully qualified URL (e.g., https://api.yourdomain.com/api)
VITE_API_BASE_URL=""
